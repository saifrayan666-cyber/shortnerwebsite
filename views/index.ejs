<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>This Person Is brand Shortlink</title>
    
    <!-- ===== FAVICON ===== -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔗</text></svg>">
    
    <!-- ===== GOOGLE FONTS ===== -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">
    
    <style>
        /* ============================================================ */
        /* PREMIUM CYBERPUNK DESIGN SYSTEM */
        /* ============================================================ */
        :root {
            --primary: #6C63FF;
            --primary-glow: rgba(108, 99, 255, 0.4);
            --secondary: #FF6584;
            --secondary-glow: rgba(255, 101, 132, 0.3);
            --accent: #00D4FF;
            --accent-glow: rgba(0, 212, 255, 0.3);
            --dark: #0A0A0F;
            --dark-card: rgba(255, 255, 255, 0.04);
            --glass: rgba(255, 255, 255, 0.06);
            --glass-border: rgba(255, 255, 255, 0.08);
            --text: #FFFFFF;
            --text-muted: rgba(255, 255, 255, 0.6);
            --telegram: #0088cc;
            --success: #00FF88;
            --danger: #FF4466;
            --warning: #FFB800;
            --neon-blue: #00D4FF;
            --neon-purple: #9B59FF;
            --neon-pink: #FF6584;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--dark);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* ===== ANIMATED BACKGROUND PARTICLES ===== */
        #particles-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* ===== NEON GLOW BACKGROUND ===== */
        body::before {
            content: '';
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: 
                radial-gradient(ellipse at 20% 50%, rgba(108, 99, 255, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(255, 101, 132, 0.06) 0%, transparent 40%),
                radial-gradient(ellipse at 50% 80%, rgba(0, 212, 255, 0.05) 0%, transparent 40%);
            z-index: 0;
            pointer-events: none;
            animation: glowPulse 8s ease-in-out infinite alternate;
        }

        @keyframes glowPulse {
            0% { opacity: 0.5; transform: scale(1) rotate(0deg); }
            100% { opacity: 1; transform: scale(1.1) rotate(3deg); }
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: var(--dark);
        }
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, var(--primary), var(--accent));
            border-radius: 50px;
        }

        /* ============================================================ */
        /* GLASSMORPHISM CARDS */
        /* ============================================================ */
        .glass-card {
            background: var(--glass);
            backdrop-filter: blur(30px) saturate(1.2);
            -webkit-backdrop-filter: blur(30px) saturate(1.2);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 
                0 25px 50px -12px rgba(0, 0, 0, 0.8),
                inset 0 1px 0 rgba(255, 255, 255, 0.05);
            position: relative;
            z-index: 1;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .glass-card::before {
            content: '';
            position: absolute;
            top: -1px;
            left: -1px;
            right: -1px;
            bottom: -1px;
            border-radius: 24px;
            background: linear-gradient(135deg, var(--primary-glow), transparent, var(--accent-glow));
            z-index: -1;
            opacity: 0.3;
            transition: opacity 0.4s;
        }

        .glass-card:hover::before {
            opacity: 0.6;
        }

        .glass-card:hover {
            transform: translateY(-4px);
            box-shadow: 
                0 30px 60px -12px rgba(108, 99, 255, 0.2),
                inset 0 1px 0 rgba(255, 255, 255, 0.08);
        }

        /* ============================================================ */
        /* NAVIGATION */
        /* ============================================================ */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 3rem;
            background: rgba(10, 10, 15, 0.85);
            backdrop-filter: blur(20px) saturate(1.2);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
            gap: 1rem;
            flex-wrap: wrap;
        }

        /* ===== LOGO ===== */
        .logo-wrapper {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            text-decoration: none;
            position: relative;
        }

        .logo-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            box-shadow: 0 0 30px rgba(108, 99, 255, 0.3);
            position: relative;
            transition: all 0.4s;
        }

        .logo-icon::after {
            content: '';
            position: absolute;
            inset: -2px;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--primary), var(--accent), var(--secondary));
            z-index: -1;
            opacity: 0.5;
            filter: blur(8px);
            animation: logoGlow 3s ease-in-out infinite alternate;
        }

        @keyframes logoGlow {
            0% { opacity: 0.3; transform: scale(1); }
            100% { opacity: 0.8; transform: scale(1.2); }
        }

        .logo-icon:hover {
            transform: scale(1.05) rotate(-5deg);
        }

        .logo-text {
            display: flex;
            flex-direction: column;
        }

        .logo-text .brand {
            font-size: 1.2rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--accent), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1.2;
            letter-spacing: -0.5px;
        }

        .logo-text .sub {
            font-size: 0.6rem;
            color: var(--text-muted);
            font-weight: 400;
            letter-spacing: 2px;
            text-transform: uppercase;
            -webkit-text-fill-color: var(--text-muted);
        }

        /* ===== NAV LINKS ===== */
        .nav-links {
            display: flex;
            gap: 1.2rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            transition: all 0.3s;
            position: relative;
            padding: 0.3rem 0;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--primary), var(--accent));
            transition: width 0.3s;
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .nav-links a:hover {
            color: var(--text);
        }

        /* ===== BUTTONS ===== */
        .btn {
            padding: 0.6rem 1.6rem;
            border: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            text-decoration: none;
            display: inline-block;
            font-family: 'Inter', sans-serif;
            position: relative;
            overflow: hidden;
        }

        .btn::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 50px;
            padding: 2px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .btn:hover::before {
            opacity: 1;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            box-shadow: 0 4px 25px rgba(108, 99, 255, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 8px 40px rgba(108, 99, 255, 0.5);
        }

        .btn-secondary {
            background: var(--glass);
            color: var(--text);
            border: 1px solid var(--glass-border);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }

        .btn-danger {
            background: linear-gradient(135deg, var(--danger), #CC2244);
            color: white;
            box-shadow: 0 4px 25px rgba(255, 68, 102, 0.3);
        }

        .btn-danger:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 8px 40px rgba(255, 68, 102, 0.5);
        }

        .btn-success {
            background: linear-gradient(135deg, var(--success), #00CC66);
            color: var(--dark);
            box-shadow: 0 4px 25px rgba(0, 255, 136, 0.3);
        }

        .btn-success:hover {
            transform: translateY(-2px) scale(1.02);
        }

        .btn-warning {
            background: linear-gradient(135deg, var(--warning), #F09B00);
            color: var(--dark);
            box-shadow: 0 4px 25px rgba(255, 184, 0, 0.3);
        }

        .btn-warning:hover {
            transform: translateY(-2px) scale(1.02);
        }

        .btn-telegram {
            background: linear-gradient(135deg, var(--telegram), #005f8a);
            color: white;
            box-shadow: 0 4px 25px rgba(0, 136, 204, 0.3);
        }

        .btn-telegram:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 8px 40px rgba(0, 136, 204, 0.5);
        }

        .btn-glow {
            animation: btnPulse 2s ease-in-out infinite;
        }

        .btn-sm {
            padding: 0.3rem 1rem;
            font-size: 0.75rem;
        }

        @keyframes btnPulse {
            0%, 100% { box-shadow: 0 4px 25px rgba(108, 99, 255, 0.3); }
            50% { box-shadow: 0 4px 50px rgba(108, 99, 255, 0.6); }
        }

        /* ============================================================ */
        /* FORMS */
        /* ============================================================ */
        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-muted);
            font-weight: 500;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
        }

        .form-control {
            width: 100%;
            padding: 0.9rem 1.2rem;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--glass-border);
            border-radius: 14px;
            color: var(--text);
            font-size: 1rem;
            transition: all 0.3s;
            outline: none;
            font-family: 'Inter', sans-serif;
        }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(108, 99, 255, 0.15), 0 0 30px rgba(108, 99, 255, 0.05);
            background: rgba(255, 255, 255, 0.06);
        }

        .form-control::placeholder {
            color: var(--text-muted);
            opacity: 0.5;
        }

        /* ============================================================ */
        /* CONTAINER */
        /* ============================================================ */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
            position: relative;
            z-index: 1;
        }

        /* ============================================================ */
        /* DASHBOARD */
        /* ============================================================ */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .dashboard-header h1 {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--text), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2.5rem;
        }

        .stat-card {
            background: var(--glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 18px;
            padding: 1.8rem 1.5rem;
            text-align: center;
            transition: all 0.4s;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(108, 99, 255, 0.05), transparent 60%);
            animation: statGlow 6s ease-in-out infinite alternate;
        }

        @keyframes statGlow {
            0% { transform: translate(-10%, -10%) scale(1); }
            100% { transform: translate(10%, 10%) scale(1.2); }
        }

        .stat-card:hover {
            transform: translateY(-4px);
            border-color: rgba(108, 99, 255, 0.3);
        }

        .stat-card .number {
            font-size: 2.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            position: relative;
            z-index: 1;
        }

        .stat-card .label {
            color: var(--text-muted);
            margin-top: 0.3rem;
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 0.5px;
            position: relative;
            z-index: 1;
        }

        /* ============================================================ */
        /* LINK CARDS */
        /* ============================================================ */
        .link-card {
            background: var(--glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 18px;
            padding: 1.8rem;
            margin-bottom: 1rem;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            position: relative;
        }

        .link-card::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 18px;
            background: linear-gradient(135deg, rgba(108, 99, 255, 0.03), rgba(0, 212, 255, 0.03));
            opacity: 0;
            transition: opacity 0.4s;
        }

        .link-card:hover::before {
            opacity: 1;
        }

        .link-card:hover {
            transform: translateY(-3px);
            border-color: rgba(108, 99, 255, 0.2);
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.5);
        }

        .link-card .link-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .link-card .link-url {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
            word-break: break-all;
            font-size: 1.1rem;
            transition: color 0.3s;
            position: relative;
            z-index: 1;
        }

        .link-card .link-url:hover {
            color: var(--primary);
        }

        .link-card .link-original {
            color: var(--text-muted);
            font-size: 0.85rem;
            word-break: break-all;
            margin-top: 0.3rem;
            position: relative;
            z-index: 1;
        }

        .link-card .link-meta {
            display: flex;
            gap: 1.5rem;
            margin-top: 0.8rem;
            font-size: 0.8rem;
            color: var(--text-muted);
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
        }

        .link-card .link-actions {
            display: flex;
            gap: 0.6rem;
            margin-top: 1rem;
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
        }

        .link-card .link-actions .btn-group {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .link-card .link-actions .edit-form {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            align-items: center;
            flex: 1;
            min-width: 200px;
        }

        .link-card .link-actions .edit-form input[type="url"] {
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--glass-border);
            border-radius: 10px;
            padding: 0.4rem 0.8rem;
            color: var(--text);
            min-width: 200px;
            flex: 1;
            font-family: 'Inter', sans-serif;
            transition: all 0.3s;
        }

        .link-card .link-actions .edit-form input[type="url"]:focus {
            border-color: var(--primary);
            outline: none;
            box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.1);
        }

        .link-card .link-actions .edit-form .edit-actions {
            display: flex;
            gap: 0.4rem;
        }

        /* ============================================================ */
        /* ALERTS */
        /* ============================================================ */
        .alert {
            padding: 1rem 1.5rem;
            border-radius: 14px;
            margin-bottom: 1.5rem;
            border: 1px solid;
            backdrop-filter: blur(10px);
        }

        .alert-success {
            background: rgba(0, 255, 136, 0.08);
            border-color: rgba(0, 255, 136, 0.2);
            color: var(--success);
        }

        .alert-danger {
            background: rgba(255, 68, 102, 0.08);
            border-color: rgba(255, 68, 102, 0.2);
            color: var(--danger);
        }

        .alert-info {
            background: rgba(0, 212, 255, 0.08);
            border-color: rgba(0, 212, 255, 0.2);
            color: var(--accent);
        }

        /* ============================================================ */
        /* LIVE USERS */
        /* ============================================================ */
        .live-counter {
            background: rgba(255, 101, 132, 0.08);
            border: 1px solid rgba(255, 101, 132, 0.15);
            border-radius: 50px;
            padding: 0.4rem 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: var(--secondary);
            font-weight: 600;
            font-size: 0.85rem;
        }

        .live-counter .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #00FF88;
            animation: pulse 1.5s ease-in-out infinite;
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.3);
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.4; transform: scale(0.7); }
        }

        .user-list {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
            margin-top: 0.5rem;
        }

        .user-badge {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--glass-border);
            border-radius: 50px;
            padding: 0.3rem 1rem;
            font-size: 0.8rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s;
        }

        .user-badge:hover {
            border-color: var(--primary);
            color: var(--text);
        }

        .user-badge .online-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #00FF88;
            display: inline-block;
            box-shadow: 0 0 10px rgba(0, 255, 136, 0.3);
        }

        /* ============================================================ */
        /* USER PROFILE */
        /* ============================================================ */
        .user-profile {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            background: rgba(0, 136, 204, 0.08);
            padding: 0.3rem 1rem 0.3rem 0.3rem;
            border-radius: 50px;
            border: 1px solid rgba(0, 136, 204, 0.15);
        }

        .user-profile .avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
            box-shadow: 0 0 20px rgba(108, 99, 255, 0.2);
        }

        .user-profile .name {
            color: var(--text);
            font-weight: 500;
            font-size: 0.85rem;
        }

        .logout-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 0.8rem;
            padding: 0.2rem 0.5rem;
            border-radius: 6px;
            transition: all 0.3s;
        }

        .logout-btn:hover {
            color: var(--danger);
            background: rgba(255, 68, 102, 0.1);
        }

        /* ============================================================ */
        /* BRAND CENTER */
        /* ============================================================ */
        .brand-center {
            text-align: center;
            padding: 1rem 0 2.5rem 0;
        }

        .brand-center h1 {
            font-size: 3.2rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--accent), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -1px;
            position: relative;
        }

        .brand-center h1::after {
            content: '✦';
            position: absolute;
            top: -20px;
            right: -30px;
            font-size: 1.5rem;
            -webkit-text-fill-color: var(--accent);
            animation: sparkle 3s ease-in-out infinite;
        }

        @keyframes sparkle {
            0%, 100% { opacity: 0.3; transform: scale(0.8) rotate(0deg); }
            50% { opacity: 1; transform: scale(1.2) rotate(180deg); }
        }

        .brand-center p {
            color: var(--text-muted);
            font-size: 1.1rem;
            margin-top: 0.5rem;
            font-weight: 300;
        }

        /* ============================================================ */
        /* SHORT LINK DISPLAY - SCANNING ANIMATION */
        /* ============================================================ */
        .short-link-display {
            background: rgba(0, 212, 255, 0.05);
            border: 1px solid rgba(0, 212, 255, 0.15);
            border-radius: 14px;
            padding: 1.2rem 1.5rem;
            margin: 1.2rem 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            position: relative;
            overflow: hidden;
        }

        .short-link-display::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 300%;
            height: 100%;
            background: linear-gradient(90deg, 
                transparent, 
                rgba(0, 212, 255, 0.05), 
                rgba(108, 99, 255, 0.05), 
                transparent
            );
            animation: scanLine 3s ease-in-out infinite;
        }

        @keyframes scanLine {
            0% { transform: translateX(-33%); }
            100% { transform: translateX(33%); }
        }

        .short-link-display .link {
            color: var(--accent);
            font-weight: 600;
            word-break: break-all;
            position: relative;
            z-index: 1;
        }

        .copy-btn {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            color: var(--text);
            padding: 0.4rem 1.2rem;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
            font-weight: 500;
            position: relative;
            z-index: 1;
        }

        .copy-btn:hover {
            background: var(--primary);
            border-color: var(--primary);
            box-shadow: 0 0 30px rgba(108, 99, 255, 0.3);
        }

        /* ============================================================ */
        /* SHORTEN FORM INLINE */
        /* ============================================================ */
        .shorten-form-inline {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            align-items: flex-end;
        }

        .shorten-form-inline .form-group {
            flex: 1;
            min-width: 150px;
            margin-bottom: 0;
        }

        .shorten-form-inline .form-group .form-control {
            padding: 0.7rem 1rem;
        }

        .shorten-form-inline .btn {
            padding: 0.7rem 1.8rem;
            min-width: 120px;
        }

        /* ============================================================ */
        /* UNLIMITED BADGE */
        /* ============================================================ */
        .unlimited-badge {
            display: inline-block;
            background: linear-gradient(135deg, var(--success), #00CC66);
            color: var(--dark);
            padding: 0.2rem 0.8rem;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.2);
        }

        /* ============================================================ */
        /* LOGIN BOX */
        /* ============================================================ */
        .login-box {
            max-width: 450px;
            margin: 3rem auto;
        }

        .telegram-icon {
            font-size: 4.5rem;
            text-align: center;
            display: block;
            margin-bottom: 1rem;
            animation: floatIcon 4s ease-in-out infinite;
        }

        @keyframes floatIcon {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }

        /* ============================================================ */
        /* FOOTER */
        /* ============================================================ */
        .footer {
            text-align: center;
            padding: 2.5rem 2rem;
            color: var(--text-muted);
            border-top: 1px solid var(--glass-border);
            margin-top: 4rem;
            background: rgba(10, 10, 15, 0.5);
            backdrop-filter: blur(10px);
            position: relative;
            z-index: 1;
        }

        .footer a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            position: relative;
        }

        .footer a::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 1px;
            background: linear-gradient(90deg, var(--primary), var(--accent));
            transition: width 0.3s;
        }

        .footer a:hover::after {
            width: 100%;
        }

        .footer a:hover {
            color: var(--text);
            text-shadow: 0 0 30px rgba(0, 212, 255, 0.3);
        }

        .footer .heart {
            color: var(--secondary);
            display: inline-block;
            animation: heartBeat 1.5s ease-in-out infinite;
        }

        @keyframes heartBeat {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.2); }
        }

        /* ============================================================ */
        /* RESPONSIVE */
        /* ============================================================ */
        @media (max-width: 992px) {
            .brand-center h1 {
                font-size: 2.4rem;
            }
        }

        @media (max-width: 768px) {
            .navbar {
                flex-direction: column;
                padding: 1rem 1.5rem;
            }

            .nav-links {
                justify-content: center;
                gap: 0.8rem;
                width: 100%;
                flex-wrap: wrap;
            }

            .container {
                padding: 1rem;
            }

            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }

            .brand-center h1 {
                font-size: 1.8rem;
            }

            .brand-center h1::after {
                display: none;
            }

            .dashboard-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .shorten-form-inline {
                flex-direction: column;
                align-items: stretch;
            }

            .shorten-form-inline .form-group {
                min-width: auto;
            }

            .link-card .link-actions .edit-form {
                flex-direction: column;
                width: 100%;
            }

            .link-card .link-actions .edit-form input[type="url"] {
                min-width: auto;
                width: 100%;
            }

            .link-card .link-actions .btn-group {
                width: 100%;
                justify-content: center;
            }

            .glass-card {
                padding: 1.5rem;
            }

            .logo-wrapper {
                width: 100%;
                justify-content: center;
            }

            .logo-text .brand {
                font-size: 1rem;
            }
        }

        @media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr 1fr;
                gap: 0.8rem;
            }

            .stat-card {
                padding: 1rem;
            }

            .stat-card .number {
                font-size: 2rem;
            }

            .brand-center h1 {
                font-size: 1.4rem;
            }

            .nav-links {
                gap: 0.5rem;
            }

            .nav-links a {
                font-size: 0.8rem;
            }

            .btn {
                padding: 0.4rem 1rem;
                font-size: 0.8rem;
            }
        }

        /* ============================================================ */
        /* FADE IN ANIMATION */
        /* ============================================================ */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
        }

        .fade-in-delay-1 { animation-delay: 0.1s; }
        .fade-in-delay-2 { animation-delay: 0.2s; }
        .fade-in-delay-3 { animation-delay: 0.3s; }
    </style>
</head>
