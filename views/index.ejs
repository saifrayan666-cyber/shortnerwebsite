<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>This Person Is brand Shortlink</title>
    <style>
        /* ===== UNIQUE DESIGN SYSTEM ===== */
        :root {
            --primary: #6C63FF;
            --primary-dark: #5A52D5;
            --secondary: #FF6584;
            --accent: #00D2FF;
            --dark: #1A1A2E;
            --dark-light: #16213E;
            --glass: rgba(255, 255, 255, 0.08);
            --glass-border: rgba(255, 255, 255, 0.15);
            --text: #FFFFFF;
            --text-muted: #B0B0C8;
            --telegram: #0088cc;
            --success: #00B894;
            --danger: #FF6B6B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: var(--dark);
            color: var(--text);
            min-height: 100vh;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(108, 99, 255, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 90% 80%, rgba(255, 101, 132, 0.1) 0%, transparent 50%);
        }

        /* ===== GLASSMORPHISM CARD ===== */
        .glass-card {
            background: var(--glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        /* ===== NAVIGATION ===== */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.2rem 4rem;
            background: rgba(26, 26, 46, 0.85);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--glass-border);
            position: sticky;
            top: 0;
            z-index: 100;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .logo {
            font-size: 1.4rem;
            font-weight: 800;
            text-decoration: none;
        }

        .logo .brand {
            background: linear-gradient(135deg, var(--primary), var(--secondary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .logo .sub {
            font-size: 0.7rem;
            display: block;
            color: var(--text-muted);
            -webkit-text-fill-color: var(--text-muted);
            font-weight: 300;
            letter-spacing: 1px;
        }

        .nav-links {
            display: flex;
            gap: 1.5rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.3s;
            font-weight: 500;
        }

        .nav-links a:hover {
            color: var(--text);
        }

        /* ===== BUTTONS ===== */
        .btn {
            padding: 0.5rem 1.4rem;
            border: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            box-shadow: 0 4px 15px rgba(108, 99, 255, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(108, 99, 255, 0.4);
        }

        .btn-secondary {
            background: var(--glass);
            color: var(--text);
            border: 1px solid var(--glass-border);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.15);
        }

        .btn-danger {
            background: linear-gradient(135deg, var(--danger), #EE5A24);
            color: white;
        }

        .btn-danger:hover {
            transform: scale(1.05);
        }

        .btn-success {
            background: linear-gradient(135deg, var(--success), #00A381);
            color: white;
        }

        .btn-success:hover {
            transform: scale(1.05);
        }

        .btn-telegram {
            background: linear-gradient(135deg, var(--telegram), #005f8a);
            color: white;
            box-shadow: 0 4px 15px rgba(0, 136, 204, 0.3);
        }

        .btn-telegram:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 136, 204, 0.4);
        }

        /* ===== FORMS ===== */
        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .form-control {
            width: 100%;
            padding: 0.9rem 1.2rem;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            color: var(--text);
            font-size: 1rem;
            transition: all 0.3s;
            outline: none;
        }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.2);
            background: rgba(255, 255, 255, 0.08);
        }

        .form-control::placeholder {
            color: var(--text-muted);
            opacity: 0.6;
        }

        /* ===== CONTAINER ===== */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        /* ===== DASHBOARD ===== */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2.5rem;
        }

        .stat-card {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 1.5rem;
            text-align: center;
        }

        .stat-card .number {
            font-size: 2.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stat-card .label {
            color: var(--text-muted);
            margin-top: 0.3rem;
        }

        /* ===== LINK CARDS ===== */
        .link-card {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: all 0.3s;
        }

        .link-card:hover {
            transform: translateY(-2px);
            border-color: var(--primary);
        }

        .link-card .link-url {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
            word-break: break-all;
            font-size: 1.1rem;
        }

        .link-card .link-original {
            color: var(--text-muted);
            font-size: 0.9rem;
            word-break: break-all;
            margin-top: 0.3rem;
        }

        .link-card .link-meta {
            display: flex;
            gap: 1.5rem;
            margin-top: 0.8rem;
            font-size: 0.85rem;
            color: var(--text-muted);
            flex-wrap: wrap;
        }

        .link-card .link-actions {
            display: flex;
            gap: 0.8rem;
            margin-top: 1rem;
            flex-wrap: wrap;
        }

        .link-card .link-actions form {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .link-card .link-actions input[type="url"] {
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--glass-border);
            border-radius: 8px;
            padding: 0.4rem 0.8rem;
            color: var(--text);
            min-width: 200px;
        }

        .link-card .link-actions input[type="url"]:focus {
            border-color: var(--primary);
            outline: none;
        }

        /* ===== ALERTS ===== */
        .alert {
            padding: 1rem 1.5rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            border: 1px solid;
        }

        .alert-success {
            background: rgba(0, 184, 148, 0.1);
            border-color: var(--success);
            color: var(--success);
        }

        .alert-danger {
            background: rgba(255, 107, 107, 0.1);
            border-color: var(--danger);
            color: var(--danger);
        }

        .alert-info {
            background: rgba(0, 210, 255, 0.1);
            border-color: var(--accent);
            color: var(--accent);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .navbar {
                flex-direction: column;
                padding: 1rem;
            }

            .nav-links {
                justify-content: center;
                gap: 0.8rem;
            }

            .container {
                padding: 1rem;
            }

            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }

            .link-card .link-actions form {
                flex-direction: column;
                width: 100%;
            }

            .link-card .link-actions input[type="url"] {
                min-width: auto;
                width: 100%;
            }
        }

        /* ===== ANIMATIONS ===== */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.5s ease-out;
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--dark);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 50px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--primary-dark);
        }

        /* ===== SHORT LINK DISPLAY ===== */
        .short-link-display {
            background: rgba(0, 210, 255, 0.05);
            border: 1px solid var(--accent);
            border-radius: 12px;
            padding: 1rem;
            margin: 1rem 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .short-link-display .link {
            color: var(--accent);
            font-weight: 600;
            word-break: break-all;
        }

        .copy-btn {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            color: var(--text);
            padding: 0.4rem 1.2rem;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .copy-btn:hover {
            background: var(--primary);
            border-color: var(--primary);
        }

        /* ===== LOGIN BOX ===== */
        .login-box {
            max-width: 450px;
            margin: 2rem auto;
        }

        .telegram-icon {
            font-size: 4rem;
            text-align: center;
            display: block;
            margin-bottom: 1rem;
        }

        /* ===== USER PROFILE ===== */
        .user-profile {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            background: rgba(0, 136, 204, 0.1);
            padding: 0.4rem 1rem;
            border-radius: 50px;
            border: 1px solid rgba(0, 136, 204, 0.2);
        }

        .user-profile .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
        }

        .user-profile .name {
            color: var(--text);
            font-weight: 500;
        }

        .logout-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 0.8rem;
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
            transition: all 0.3s;
        }

        .logout-btn:hover {
            color: var(--danger);
            background: rgba(255, 107, 107, 0.1);
        }

        /* ===== LIVE USERS COUNTER ===== */
        .live-counter {
            background: rgba(255, 101, 132, 0.1);
            border: 1px solid rgba(255, 101, 132, 0.2);
            border-radius: 50px;
            padding: 0.4rem 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--secondary);
            font-weight: 600;
        }

        .live-counter .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #00ff88;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(0.8); }
            100% { opacity: 1; transform: scale(1); }
        }

        .user-list {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: 0.5rem;
        }

        .user-badge {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--glass-border);
            border-radius: 50px;
            padding: 0.2rem 0.8rem;
            font-size: 0.8rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .user-badge .online-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #00ff88;
            display: inline-block;
        }

        /* ===== BRAND CENTER ===== */
        .brand-center {
            text-align: center;
            padding: 1rem 0 2rem 0;
        }

        .brand-center h1 {
            font-size: 2.8rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
        }

        .brand-center p {
            color: var(--text-muted);
            font-size: 1.1rem;
            margin-top: 0.3rem;
        }

        /* ===== SHORTEN FORM IN DASHBOARD ===== */
        .shorten-form-inline {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            align-items: flex-end;
        }

        .shorten-form-inline .form-group {
            flex: 1;
            min-width: 150px;
            margin-bottom: 0;
        }

        .shorten-form-inline .form-group .form-control {
            padding: 0.7rem 1rem;
        }

        .shorten-form-inline .btn {
            padding: 0.7rem 1.8rem;
            min-width: 120px;
        }

        @media (max-width: 768px) {
            .shorten-form-inline {
                flex-direction: column;
                align-items: stretch;
            }
            .shorten-form-inline .form-group {
                min-width: auto;
            }
        }
    </style>
</head>
<body>

    <!-- ============================================================ -->
    <!-- NAVIGATION -->
    <!-- ============================================================ -->
    <nav class="navbar">
        <a href="/" class="logo">
            <span class="brand">🔗 This Person Is brand Shortlink</span>
            <span class="sub">Smart URL Shortener</span>
        </a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/dashboard">Dashboard</a>

            <!-- Live Users Counter -->
            <span class="live-counter">
                <span class="dot"></span>
                <span id="liveUserCount"><%= typeof onlineUsers !== 'undefined' ? onlineUsers : 0 %> Online</span>
            </span>

            <% if (typeof user !== 'undefined' && user) { %>
                <div class="user-profile">
                    <div class="avatar"><%= user.name.charAt(0) %></div>
                    <span class="name"><%= user.name %></span>
                    <form action="/logout" method="POST" style="display: inline;">
                        <button type="submit" class="logout-btn" title="Logout">✕</button>
                    </form>
                </div>
            <% } else { %>
                <a href="/login" class="btn btn-telegram">🔑 Login with Telegram</a>
            <% } %>
        </div>
    </nav>

    <!-- ============================================================ -->
    <!-- MAIN CONTENT -->
    <!-- ============================================================ -->
    <div class="container">

        <!-- ===== ALERTS ===== -->
        <% 
            // Get error/success from query params (for dashboard redirects)
            const queryError = typeof error !== 'undefined' ? error : null;
            const querySuccess = typeof success !== 'undefined' ? success : null;
            const queryInfo = typeof info !== 'undefined' ? info : null;
        %>
        <% if (queryError) { %>
            <div class="alert alert-danger"><%= queryError %></div>
        <% } %>
        <% if (querySuccess) { %>
            <div class="alert alert-success"><%= querySuccess %></div>
        <% } %>
        <% if (queryInfo) { %>
            <div class="alert alert-info"><%= queryInfo %></div>
        <% } %>


        <!-- ========================================================== -->
        <!-- PAGE: LOGIN -->
        <!-- ========================================================== -->
        <% if (page === 'login') { %>
            <div class="login-box fade-in">
                <div class="glass-card" style="text-align: center;">
                    <span class="telegram-icon">📱</span>
                    <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">Telegram Login</h1>
                    <p style="color: var(--text-muted); margin-bottom: 2rem;">
                        Login with your Telegram ID to access all features
                    </p>

                    <form action="/login" method="POST">
                        <div class="form-group">
                            <label for="telegramId">Telegram ID</label>
                            <input type="text" class="form-control" id="telegramId" name="telegramId"
                                   placeholder="Enter your Telegram ID (e.g., 123456789)" required>
                        </div>
                        <div class="form-group">
                            <label for="username">Your Name</label>
                            <input type="text" class="form-control" id="username" name="username"
                                   placeholder="Enter your full name" required>
                        </div>
                        <button type="submit" class="btn btn-telegram" style="width: 100%;">
                            🔑 Login with Telegram
                        </button>
                    </form>

                    <div style="margin-top: 1.5rem; padding: 1rem; background: rgba(0, 136, 204, 0.05); border-radius: 12px;">
                        <p style="color: var(--text-muted); font-size: 0.9rem;">
                            💡 Don't have a Telegram ID? Get it from
                            <a href="https://t.me/userinfobot" target="_blank" style="color: var(--telegram);">@userinfobot</a>
                            on Telegram
                        </p>
                    </div>
                </div>
            </div>
        <% } %>


        <!-- ========================================================== -->
        <!-- PAGE: HOME -->
        <!-- ========================================================== -->
        <% if (page === 'home') { %>
            <!-- Brand Header -->
            <div class="brand-center fade-in">
                <h1>This Person Is brand Shortlink</h1>
                <p>Create, manage and track your short links</p>
            </div>

            <!-- Main Shorten Form -->
            <div class="glass-card fade-in" style="max-width: 800px; margin: 0 auto;">
                <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">
                    Shorten Your <span style="background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Links</span>
                </h1>
                <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 2rem;">
                    Create short, memorable links that update automatically when you change the destination.
                </p>

                <% if (typeof user !== 'undefined' && user) { %>
                    <form action="/shorten" method="POST">
                        <div class="form-group">
                            <label for="originalUrl">Original URL</label>
                            <input type="url" class="form-control" id="originalUrl" name="originalUrl"
                                   placeholder="https://example.com/very-long-url" required>
                        </div>
                        <div class="form-group">
                            <label for="customSlug">Custom Slug (Optional)</label>
                            <input type="text" class="form-control" id="customSlug" name="customSlug"
                                   placeholder="my-link">
                        </div>
                        <button type="submit" class="btn btn-primary" style="width: 100%;">🚀 Create Short Link</button>
                    </form>

                    <% if (typeof shortUrl !== 'undefined' && shortUrl) { %>
                        <div class="short-link-display">
                            <span class="link"><%= shortUrl %></span>
                            <button class="copy-btn" onclick="copyToClipboard('<%= shortUrl %>')">📋 Copy</button>
                        </div>
                    <% } %>
                <% } else { %>
                    <div style="text-align: center; padding: 2rem; background: var(--glass); border-radius: 16px;">
                        <p style="font-size: 1.2rem; margin-bottom: 1rem;">🔐 Please login with Telegram to create short links</p>
                        <a href="/login" class="btn btn-telegram">Login with Telegram</a>
                    </div>
                <% } %>
            </div>

            <!-- Live Users -->
            <div class="glass-card fade-in" style="margin-top: 2rem;">
                <h3>👥 Live Users</h3>
                <p style="color: var(--text-muted); margin-bottom: 0.5rem;">
                    Currently <strong><%= typeof onlineUsers !== 'undefined' ? onlineUsers : 0 %></strong> users are online
                </p>
                <div class="user-list" id="userList">
                    <% if (typeof onlineUserList !== 'undefined' && onlineUserList && onlineUserList.length > 0) { %>
                        <% onlineUserList.forEach(function(u) { %>
                            <span class="user-badge">
                                <span class="online-dot"></span>
                                <%= u.name %>
                            </span>
                        <% }); %>
                    <% } else { %>
                        <span style="color: var(--text-muted);">No users online</span>
                    <% } %>
                </div>
            </div>

            <!-- Features -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-top: 2rem;">
                <div class="glass-card" style="text-align: center;">
                    <div style="font-size: 3rem;">🔄</div>
                    <h3>Updateable Links</h3>
                    <p style="color: var(--text-muted);">Change destination URL anytime, all short links update automatically</p>
                </div>
                <div class="glass-card" style="text-align: center;">
                    <div style="font-size: 3rem;">👀</div>
                    <h3>Click Tracking</h3>
                    <p style="color: var(--text-muted);">Monitor how many times your links are clicked</p>
                </div>
                <div class="glass-card" style="text-align: center;">
                    <div style="font-size: 3rem;">📊</div>
                    <h3>Live Users</h3>
                    <p style="color: var(--text-muted);">See who's using the site in real-time</p>
                </div>
            </div>
        <% } %>


        <!-- ========================================================== -->
        <!-- PAGE: DASHBOARD -->
        <!-- ========================================================== -->
        <% if (page === 'dashboard') { %>
            <div class="fade-in">

                <!-- Dashboard Header -->
                <div class="dashboard-header">
                    <h1>📊 My Dashboard</h1>
                    <a href="/" class="btn btn-primary">+ Create New Link</a>
                </div>

                <!-- Stats -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="number"><%= typeof links !== 'undefined' && links ? links.length : 0 %></div>
                        <div class="label">Total Links</div>
                    </div>
                    <div class="stat-card">
                        <div class="number"><%= typeof totalClicks !== 'undefined' ? totalClicks : 0 %></div>
                        <div class="label">Total Clicks</div>
                    </div>
                    <div class="stat-card">
                        <div class="number"><%= typeof onlineUsers !== 'undefined' ? onlineUsers : 0 %></div>
                        <div class="label">Online Users</div>
                    </div>
                </div>

                <!-- Quick Create Form -->
                <div class="glass-card" style="margin-bottom: 2rem;">
                    <h3 style="margin-bottom: 0.5rem;">🔗 Create New Short Link</h3>
                    <form action="/shorten" method="POST" class="shorten-form-inline">
                        <div class="form-group">
                            <input type="url" class="form-control" name="originalUrl"
                                   placeholder="Enter your long URL" required>
                        </div>
                        <div class="form-group">
                            <input type="text" class="form-control" name="customSlug"
                                   placeholder="Custom slug (optional)">
                        </div>
                        <button type="submit" class="btn btn-primary">🚀 Shorten</button>
                    </form>
                </div>

                <!-- Links List -->
                <h2 style="margin-bottom: 1.5rem;">My Short Links</h2>

                <% if (typeof links !== 'undefined' && links && links.length > 0) { %>
                    <% links.forEach(function(link) { %>
                        <div class="link-card">
                            <div>
                                <a href="/<%= link.shortCode %>" target="_blank" class="link-url">
                                    🔗 <%= link.shortUrl %>
                                </a>
                            </div>
                            <div class="link-original">→ <%= link.originalUrl %></div>
                            <div class="link-meta">
                                <span>👁️ <%= link.clicks %> clicks</span>
                                <span>📅 <%= link.createdAt %></span>
                                <span>🆔 <%= link.shortCode %></span>
                            </div>
                            <div class="link-actions">
                                <!-- Update Form -->
                                <form action="/update-link/<%= link.id %>" method="POST">
                                    <input type="url" name="newUrl" placeholder="Enter new URL" required>
                                    <button type="submit" class="btn btn-primary" style="padding: 0.3rem 1rem;">
                                        🔄 Update
                                    </button>
                                </form>
                                <!-- Delete Form -->
                                <form action="/delete-link/<%= link.id %>" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-danger" style="padding: 0.3rem 1rem;"
                                            onclick="return confirm('Are you sure you want to delete this link?')">
                                        🗑️ Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="glass-card" style="text-align: center; padding: 3rem;">
                        <p style="color: var(--text-muted); font-size: 1.2rem;">You haven't created any links yet</p>
                        <p style="color: var(--text-muted); margin-top: 0.5rem;">
                            Use the form above to create your first short link!
                        </p>
                    </div>
                <% } %>

            </div>
        <% } %>

    </div>
    <!-- ===== END CONTAINER ===== -->


    <!-- ============================================================ -->
    <!-- FOOTER -->
    <!-- ============================================================ -->
    <footer style="text-align: center; padding: 2rem; color: var(--text-muted); border-top: 1px solid var(--glass-border); margin-top: 4rem;">
        <p>🔗 This Person Is brand Shortlink &bull; Built with ❤️ &bull; Powered by Telegram</p>
        <p style="font-size: 0.8rem; margin-top: 0.5rem;">© 2026 All rights reserved</p>
    </footer>


    <!-- ============================================================ -->
    <!-- SCRIPTS -->
    <!-- ============================================================ -->
    <script>
        // Copy to clipboard
        function copyToClipboard(text) {
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(() => {
                    alert('✅ Link copied to clipboard!');
                }).catch(() => {
                    fallbackCopy(text);
                });
            } else {
                fallbackCopy(text);
            }
        }

        function fallbackCopy(text) {
            const input = document.createElement('input');
            input.value = text;
            document.body.appendChild(input);
            input.select();
            document.execCommand('copy');
            document.body.removeChild(input);
            alert('✅ Link copied to clipboard!');
        }

        // Update live user count every 10 seconds
        setInterval(async () => {
            try {
                const response = await fetch('/api/online-users');
                const data = await response.json();

                const countEl = document.getElementById('liveUserCount');
                if (countEl) {
                    countEl.textContent = (data.count || 0) + ' Online';
                }

                const listEl = document.getElementById('userList');
                if (listEl && data.users) {
                    if (data.users.length > 0) {
                        listEl.innerHTML = data.users.map(u =>
                            `<span class="user-badge"><span class="online-dot"></span>${u.name}</span>`
                        ).join('');
                    } else {
                        listEl.innerHTML = '<span style="color: var(--text-muted);">No users online</span>';
                    }
                }
            } catch (e) {
                // Silent fail - no need to spam console
            }
        }, 10000);
    </script>

</body>
</html>
