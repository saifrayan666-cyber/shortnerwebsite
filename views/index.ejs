    <!-- ============================================================ -->
    <!-- SCRIPTS -->
    <!-- ============================================================ -->
    <script>
        // ============================================================
        // ANIMATED PARTICLES
        // ============================================================
        (function() {
            const canvas = document.getElementById('particles-canvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let mouseX = 0;
            let mouseY = 0;

            function resizeCanvas() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resizeCanvas();
            window.addEventListener('resize', resizeCanvas);

            class Particle {
                constructor() {
                    this.x = Math.random() * canvas.width;
                    this.y = Math.random() * canvas.height;
                    this.size = Math.random() * 2 + 0.5;
                    this.speedX = (Math.random() - 0.5) * 0.5;
                    this.speedY = (Math.random() - 0.5) * 0.5;
                    this.opacity = Math.random() * 0.5 + 0.2;
                    this.color = `rgba(108, 99, 255, ${this.opacity})`;
                }

                update() {
                    this.x += this.speedX;
                    this.y += this.speedY;

                    const dx = mouseX - this.x;
                    const dy = mouseY - this.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 150) {
                        const force = (150 - dist) / 150 * 0.02;
                        this.x -= dx * force;
                        this.y -= dy * force;
                    }

                    if (this.x > canvas.width) this.x = 0;
                    if (this.x < 0) this.x = canvas.width;
                    if (this.y > canvas.height) this.y = 0;
                    if (this.y < 0) this.y = canvas.height;
                }

                draw() {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fillStyle = this.color;
                    ctx.fill();
                }
            }

            function initParticles() {
                const count = Math.min(100, Math.floor((canvas.width * canvas.height) / 10000));
                particles = [];
                for (let i = 0; i < count; i++) {
                    particles.push(new Particle());
                }
            }
            initParticles();

            function drawConnections() {
                for (let i = 0; i < particles.length; i++) {
                    for (let j = i + 1; j < particles.length; j++) {
                        const dx = particles[i].x - particles[j].x;
                        const dy = particles[i].y - particles[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < 120) {
                            ctx.beginPath();
                            ctx.strokeStyle = `rgba(108, 99, 255, ${0.08 * (1 - dist / 120)})`;
                            ctx.lineWidth = 0.5;
                            ctx.moveTo(particles[i].x, particles[i].y);
                            ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.stroke();
                        }
                    }
                }
            }

            function animateParticles() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                particles.forEach(p => {
                    p.update();
                    p.draw();
                });
                drawConnections();
                requestAnimationFrame(animateParticles);
            }
            animateParticles();

            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
            });

            window.addEventListener('resize', () => {
                resizeCanvas();
                initParticles();
            });
        })();

        // ============================================================
        // COPY TO CLIPBOARD - FIXED VERSION
        // ============================================================
        function copyToClipboard(text) {
            // Clean the text
            const cleanText = String(text).trim();
            
            console.log('📋 Copying:', cleanText);
            console.log('📋 Length:', cleanText.length);
            
            if (!cleanText || cleanText === '') {
                showToast('❌ Error: Nothing to copy');
                console.error('❌ Empty text to copy');
                return;
            }
            
            // Method 1: Modern clipboard API
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(cleanText).then(() => {
                    showToast('✅ Link copied to clipboard!');
                    console.log('✅ Copied successfully via clipboard API');
                }).catch((err) => {
                    console.error('❌ Clipboard API failed:', err);
                    fallbackCopy(cleanText);
                });
            } else {
                // Method 2: Fallback
                fallbackCopy(cleanText);
            }
        }

        // Fallback copy method
        function fallbackCopy(text) {
            try {
                // Create a temporary textarea
                const textarea = document.createElement('textarea');
                textarea.value = text;
                textarea.style.position = 'fixed';
                textarea.style.opacity = '0';
                textarea.style.pointerEvents = 'none';
                textarea.style.width = '1px';
                textarea.style.height = '1px';
                textarea.style.top = '0';
                textarea.style.left = '0';
                document.body.appendChild(textarea);
                
                // Select and copy
                textarea.select();
                textarea.setSelectionRange(0, 99999);
                
                const success = document.execCommand('copy');
                document.body.removeChild(textarea);
                
                if (success) {
                    showToast('✅ Link copied to clipboard!');
                    console.log('✅ Copied successfully via fallback');
                } else {
                    showToast('❌ Failed to copy. Please copy manually.');
                    console.error('❌ Fallback copy failed');
                }
            } catch (err) {
                console.error('❌ Copy error:', err);
                showToast('❌ Failed to copy. Please copy manually.');
            }
        }

        // ============================================================
        // TOAST NOTIFICATION
        // ============================================================
        function showToast(message) {
            // Remove existing toast
            const existingToast = document.querySelector('.custom-toast');
            if (existingToast) {
                existingToast.remove();
            }
            
            const toast = document.createElement('div');
            toast.className = 'custom-toast';
            toast.textContent = message;
            
            Object.assign(toast.style, {
                position: 'fixed',
                bottom: '30px',
                left: '50%',
                transform: 'translateX(-50%)',
                background: 'rgba(10,10,15,0.95)',
                backdropFilter: 'blur(20px)',
                color: '#fff',
                padding: '1rem 2rem',
                borderRadius: '14px',
                border: '1px solid rgba(255,255,255,0.08)',
                boxShadow: '0 20px 40px -12px rgba(0,0,0,0.8), 0 0 30px rgba(108,99,255,0.15)',
                zIndex: '9999',
                fontFamily: 'Inter, sans-serif',
                fontWeight: '500',
                fontSize: '0.95rem',
                maxWidth: '90%',
                textAlign: 'center',
                animation: 'fadeIn 0.4s ease',
                transition: 'opacity 0.4s ease'
            });
            
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => {
                    if (toast.parentNode) {
                        toast.remove();
                    }
                }, 400);
            }, 3000);
        }

        // ============================================================
        // EVENT LISTENERS FOR COPY BUTTONS
        // ============================================================
        document.addEventListener('DOMContentLoaded', function() {
            // Find all copy buttons
            const copyButtons = document.querySelectorAll('.copy-link-btn');
            console.log('🔍 Found', copyButtons.length, 'copy buttons');
            
            copyButtons.forEach(function(btn, index) {
                const url = btn.getAttribute('data-url');
                console.log(`🔗 Button ${index}:`, url);
                
                // Remove any existing click listeners
                btn.removeEventListener('click', btn._copyHandler);
                
                // Add new click listener
                btn._copyHandler = function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    const linkUrl = this.getAttribute('data-url');
                    console.log('🖱️ Button clicked, URL:', linkUrl);
                    copyToClipboard(linkUrl);
                };
                
                btn.addEventListener('click', btn._copyHandler);
            });
        });

        // ============================================================
        // UPDATE LIVE USER COUNT
        // ============================================================
        setInterval(async () => {
            try {
                const response = await fetch('/api/online-users');
                const data = await response.json();

                const countEl = document.getElementById('liveUserCount');
                if (countEl) {
                    countEl.textContent = (data.count || 0) + ' Online';
                }

                const listEl = document.getElementById('userList');
                if (listEl && data.users) {
                    if (data.users.length > 0) {
                        listEl.innerHTML = data.users.map(u =>
                            `<span class="user-badge"><span class="online-dot"></span>${u.name}</span>`
                        ).join('');
                    } else {
                        listEl.innerHTML = '<span style="color: var(--text-muted);">No users online</span>';
                    }
                }
            } catch (e) {}
        }, 10000);

        // ============================================================
        // PROCESSING ANIMATION ON FORM SUBMIT
        // ============================================================
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('shortenForm');
            const btn = document.getElementById('shortenBtn');
            
            if (form && btn) {
                form.addEventListener('submit', function() {
                    const originalText = btn.innerHTML;
                    btn.innerHTML = '🔮 Processing...';
                    btn.disabled = true;
                    btn.style.opacity = '0.7';
                    
                    setTimeout(() => {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                        btn.style.opacity = '1';
                    }, 3000);
                });
            }
        });
    </script>

</body>
</html>
